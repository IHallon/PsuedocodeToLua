-- Get 10 random numbers from the program, have the program classify each number as an even number or an odd number, and have the program count how many even numbers and odd numbers of the 10 numbers there were.

-- Functions
math.randomseed(os.time())
math.random() math.random() math.random()

-- Variables
evenCounter = 0
oddCounter = 0

for x = 1, 10 do -- Repeats the program 10 times.
	randomNumber = math.random(1,100) -- Generates a random number between 1 and 100.
	print(randomNumber) -- Prints out a random number.
	
	if randomNumber % 2 == 0 then -- If the random number is even.
		print("Even") -- Prints out that the number is even.
		evenCounter = evenCounter + 1 -- Adds 1 to the even number counter.
	else -- If the random number is odd.
		print("Odd") -- Prints out that the number is odd.
		oddCounter = oddCounter + 1 -- Adds 1 to the odd number counter.
	end
end

print("There were " .. evenCounter .. "even numbers and " .. evenCounter .. "odd numbers.") -- Print the result.
